# GitHub Container Registry Configuration
# Format: owner/repository (e.g., meta-level-public/aas-suite-community)
GITHUB_REPOSITORY=meta-level-public/aas-suite-community

# Image Tag (main, latest, v1.0.0, etc.)
IMAGE_TAG=main

# Database Configuration
POSTGRES_PASSWORD=changeme123

# Application Configuration
# IMPORTANT: Change this to a secure random string (minimum 32 characters)
JWT_SECRET=your-very-secure-secret-key-with-at-least-32-characters-please-change-this

# Keycloak Configuration (Community SSO)
KEYCLOAK_DB_PASSWORD=keycloak
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Optional: Override default ports
# FRONTEND_PORT=80
# FRONTEND_HTTPS_PORT=443
# DESIGNER_PORT=8080
# GATEWAY_PORT=8081
